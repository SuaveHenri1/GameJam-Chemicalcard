  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  messages:
  - actorID: 0
    message: "Bom dia, criatura! Tudo certo com voc\xEA?"
  - actorID: 0
    message: "Eu t\xF4 tranquilo..."
  - actorID: 0
    message: Tirando que acabou meu FERTILIZANTE.
  - actorID: 0
    message: "Mas sei l\xE1... resolvo isso depois."
  - actorID: 0
    message: "Seria muito conveniente se voc\xEA pudesse criar um pouco de FERTILIZANTE
      assim do nada, n\xE9, amiguinho?"
  - actorID: 0
    message: "Pena que as coisas n\xE3o funcionam assim, hahaha..."
  actors:
  - name: 
  messagemFinal:
  - actorID: 0
    message: Obrigado criatura!!!
