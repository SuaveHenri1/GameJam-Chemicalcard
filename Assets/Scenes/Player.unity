  m_Script: {fileID: 11500000, guid: 380355600ce568d4899fe47ca5ae57ba, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  messages:
  - actorID: 0
    message: "Mesas arrumadas, bebidas em ordem, ch\xE3o limpo, suprimentos separados..."
  - actorID: 0
    message: Mas eu sinto que estou esquecendo de algo...
  - actorID: 0
    message: ...
  - actorID: 0
    message: O SAL!
  - actorID: 0
    message: "Eu tinha que comprar SAL! E j\xE1 \xE9 quase meio-dia... e agora?!"
  - actorID: 0
    message: "Ah, criatura! Voc\xEA por aqui?"
  - actorID: 0
    message: "Se veio comer na minha taverna... infelizmente n\xE3o sei se vou conseguir
      abrir hoje."
  - actorID: 0
    message: Eu estou... sem SAL.
  actors:
  - name: 
  messagemFinal:
  - actorID: 0
    message: Obrigado criatura!!!
